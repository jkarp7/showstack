      "grid_column": 0,
      "grid_row": 1,
      "column_span": 12,
      "row_span": 1,
      "layer": 0,
      "style": {
        "fontFamily": "Arial",
        "fontSize": 11,
        "textAlign": "center",
        "padding": 2
      }
    },
    {
      "element_type": "shape",
      "config": {
        "shapeType": "line",
        "thickness": 1,
        "color": "#000000"
      },
      "grid_column": 0,
      "grid_row": 3,
      "column_span": 12,
      "row_span": 1,
      "layer": 0,
      "style": {}
    },
    {
      "element_type": "equipment_list",
      "config": {},
      "grid_column": 0,
      "grid_row": 4,
      "column_span": 12,
      "row_span": 20,
      "layer": 0,
      "style": {
        "fontFamily": "Arial",
        "fontSize": 9,
        "padding": 0
      }
    }
  ]
}
