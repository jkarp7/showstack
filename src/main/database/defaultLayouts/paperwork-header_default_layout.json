        "textAlign": "left",
        "color": "#6B7280",
        "backgroundColor": "transparent",
        "padding": 4
      }
    },
    {
      "element_type": "dataField",
      "config": {
        "fieldType": "generated_date",
        "label": "Generated:",
        "showLabel": true
      },
      "grid_column": 0,
      "grid_row": 6,
      "column_span": 6,
      "row_span": 1,
      "layer": 0,
      "style": {
        "fontFamily": "Arial",
        "fontSize": 9,
        "textAlign": "left",
        "color": "#6B7280",
        "backgroundColor": "transparent",
        "padding": 4
      }
    },
    {
      "element_type": "dataField",
      "config": {
        "fieldType": "ld_phone",
        "showLabel": false
      },
      "grid_column": 6,
      "grid_row": 6,
      "column_span": 6,
      "row_span": 1,
      "layer": 0,
      "style": {
        "fontFamily": "Arial",
        "fontSize": 9,
        "textAlign": "left",
        "color": "#6B7280",
        "backgroundColor": "transparent",
        "padding": 4
      }
    }
  ]
}
