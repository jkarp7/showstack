// ShowStack:Manager Database Schema
// Production & Tour Management with Plaid Integration

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===== USER & AUTHENTICATION =====

model User {
  id                String    @id @default(uuid())
  email             String    @unique
  name              String
  passwordHash      String

  // Subscription
  subscriptionTier  String    // "pm", "tour", "producer"
  subscriptionStatus String   // "active", "trial", "cancelled", "expired"
  stripeCustomerId  String?

  // Plaid
  plaidItemId       String?   // Plaid Item ID for bank connection

  projects          Project[]
  plaidAccounts     PlaidAccount[]
  inventory         Inventory[]

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

// ===== PROJECT MANAGEMENT =====

model Project {
  id                String    @id @default(uuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  name              String
  type              String    // "venue", "tour", "festival", "corporate", "other"
  status            String    // "bidding", "prep", "in_production", "on_road", "closed"

  // Dates
  startDate         DateTime?
  endDate           DateTime?

  // Budget
  totalBudget       Decimal   @db.Decimal(12, 2)

  // Relationships
  budgets           Budget[]
  purchaseOrders    PurchaseOrder[]
  transactions      Transaction[]
  venueStops        VenueStop[]
  settlements       Settlement[]

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([userId])
  @@index([status])
}

// ===== BUDGET MANAGEMENT (PM Edition) =====

model Budget {
  id                String    @id @default(uuid())
  projectId         String
  project           Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  department        String    // "lighting", "audio", "video", "travel", etc.
  category          String    // "equipment", "labor", "transportation", etc.

  allocatedAmount   Decimal   @db.Decimal(12, 2)
  committedAmount   Decimal   @db.Decimal(12, 2) @default(0)
  spentAmount       Decimal   @db.Decimal(12, 2) @default(0)

  notes             String?   @db.Text

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([projectId, department, category])
  @@index([projectId])
}

// ===== VENDOR & PURCHASE ORDERS (PM Edition) =====

model Vendor {
  id                String    @id @default(uuid())

  name              String
  primaryContact    String?
  email             String?
  phone             String?
  address           String?

  // Vendor type
  type              String    // "rental", "labor", "transportation", etc.

  // Payment terms
  paymentTerms      String?   // "Net 30", "COD", etc.

  purchaseOrders    PurchaseOrder[]

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([name])
}

model PurchaseOrder {
  id                String    @id @default(uuid())
  projectId         String
  project           Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  vendorId          String
  vendor            Vendor    @relation(fields: [vendorId], references: [id])

  poNumber          String    @unique
  amount            Decimal   @db.Decimal(12, 2)

  status            String    // "pending", "approved", "sent", "paid", "cancelled"

  issueDate         DateTime  @default(now())
  paymentTerms      String?
  dueDate           DateTime?

  department        String
  category          String

  description       String?   @db.Text
  notes             String?   @db.Text

  // Matching
  matchedTransactions Transaction[]

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([projectId])
  @@index([vendorId])
  @@index([status])
}

// ===== PLAID INTEGRATION =====

model PlaidAccount {
  id                String    @id @default(uuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Plaid identifiers
  plaidAccountId    String    @unique
  plaidItemId       String
  accessToken       String    @db.Text // Encrypted

  // Account info
  institutionName   String
  accountName       String
  accountType       String    // "checking", "savings", "credit"
  accountMask       String    // Last 4 digits

  // Sync status
  lastSync          DateTime?
  syncFrequency     String    @default("daily") // "daily", "weekly"
  isActive          Boolean   @default(true)

  transactions      Transaction[]

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([userId])
  @@index([plaidItemId])
}

model Transaction {
  id                    String    @id @default(uuid())

  // Plaid data
  plaidTransactionId    String    @unique
  plaidAccountId        String
  account               PlaidAccount @relation(fields: [plaidAccountId], references: [id], onDelete: Cascade)

  // Transaction details
  amount                Decimal   @db.Decimal(12, 2)
  date                  DateTime
  merchantName          String
  category              Json      // Plaid categories array

  // Matching
  matchedPOId           String?
  matchedPO             PurchaseOrder? @relation(fields: [matchedPOId], references: [id])

  matchedSettlementId   String?
  matchedSettlement     Settlement? @relation(fields: [matchedSettlementId], references: [id])

  matchingConfidence    Float?    // 0-1 score
  manuallyMatched       Boolean   @default(false)
  matchedAt             DateTime?

  // Categorization
  projectId             String?
  project               Project?  @relation(fields: [projectId], references: [id])

  department            String?
  expenseCategory       String?   // "hotel", "meal", "equipment", etc.

  // Flags
  isReconciled          Boolean   @default(false)
  needsReview           Boolean   @default(false)
  reviewNotes           String?   @db.Text

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([date])
  @@index([merchantName])
  @@index([matchedPOId])
  @@index([needsReview])
}

// ===== TOUR EDITION =====

model VenueStop {
  id                String    @id @default(uuid())
  projectId         String
  project           Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  venueName         String
  city              String
  state             String?
  country           String    @default("USA")

  // Dates
  loadInDate        DateTime
  showDate          DateTime
  loadOutDate       DateTime?

  // Advance status
  advanceStatus     String    @default("pending") // "pending", "in_progress", "complete"
  advanceNotes      String?   @db.Text

  // Per diems
  perDiemBudget     Decimal   @db.Decimal(10, 2) @default(0)
  perDiemSpent      Decimal   @db.Decimal(10, 2) @default(0)

  // Local crew
  localCrewCount    Int?
  localCrewCost     Decimal?  @db.Decimal(10, 2)

  // Settlement
  settlementStatus  String    @default("pending") // "pending", "in_progress", "complete"
  settlement        Settlement?

  sortOrder         Int

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([projectId, showDate])
}

model Settlement {
  id                String    @id @default(uuid())
  venueStopId       String    @unique
  venueStop         VenueStop @relation(fields: [venueStopId], references: [id], onDelete: Cascade)

  // Financials
  grossRevenue      Decimal?  @db.Decimal(12, 2)
  expenses          Decimal   @db.Decimal(12, 2) @default(0)
  netRevenue        Decimal?  @db.Decimal(12, 2)

  // Expense breakdown
  perDiemTotal      Decimal   @db.Decimal(10, 2) @default(0)
  localCrewTotal    Decimal   @db.Decimal(10, 2) @default(0)
  transportTotal    Decimal   @db.Decimal(10, 2) @default(0)
  otherExpenses     Decimal   @db.Decimal(10, 2) @default(0)

  // Status
  status            String    @default("draft") // "draft", "pending", "approved", "paid"
  approvedBy        String?
  approvedAt        DateTime?

  notes             String?   @db.Text

  // Matching
  matchedTransactions Transaction[]

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

// ===== PRODUCER EDITION =====

model Inventory {
  id                String    @id @default(uuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  itemName          String
  itemType          String    // "lighting", "audio", "video", etc.

  quantity          Int
  availableQty      Int
  onRentQty         Int       @default(0)
  inServiceQty      Int       @default(0)

  rentalRate        Decimal?  @db.Decimal(10, 2)
  purchaseValue     Decimal?  @db.Decimal(12, 2)

  notes             String?   @db.Text

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([userId])
  @@index([itemType])
}
