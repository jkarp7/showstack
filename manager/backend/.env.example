# Server
NODE_ENV=development
PORT=5000

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/showstack_manager?schema=public"

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Plaid API
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret
PLAID_ENV=sandbox
# Options: sandbox | development | production

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Encryption (for Plaid tokens)
ENCRYPTION_KEY=64_character_hex_string_for_aes_256_encryption_change_this

# SendGrid (Email)
SENDGRID_API_KEY=SG.your_sendgrid_api_key
FROM_EMAIL=noreply@showstackmanager.com

# Redis (for background jobs)
REDIS_URL=redis://localhost:6379

# CORS
CORS_ORIGIN=http://localhost:3000
