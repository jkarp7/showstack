{
  "name": "showstack",
  "productName": "ShowStack",
  "version": "0.1.0-alpha",
  "description": "Modern production management software for live entertainment",
  "author": {
    "name": "Lytrix",
    "email": "info@showstack.app"
  },
  "license": "UNLICENSED",
  "private": true,
  "type": "module",
  "main": "out/main/index.cjs",
  "workspaces": [
    "packages/*"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/jkarp7/showstack.git"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist:linux": "npm run build && electron-builder --linux",
    "dist:all": "npm run build && electron-builder --mac --win --linux",
    "dev:poc": "cd proof-of-concept && npm run dev",
    "build:poc": "cd proof-of-concept && npm run build",
    "test:poc": "cd proof-of-concept && npm test",
    "install:all": "npm install && cd proof-of-concept && npm install",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:run": "vitest run",
    "test:rebuild": "npm rebuild better-sqlite3",
    "test:supabase": "npx tsx scripts/test-supabase.ts",
    "test:powersync": "npx tsx scripts/test-powersync.ts",
    "lint": "eslint --cache .",
    "lint:fix": "eslint --cache . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "keywords": [
    "lighting",
    "production",
    "theater",
    "entertainment",
    "lightwright",
    "electron"
  ],
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "autoprefixer": "^10.4.22",
    "electron": "^39.2.1",
    "electron-builder": "^26.0.12",
    "electron-vite": "^4.0.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.0",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^16.2.7",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vite": "^7.2.2",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@powersync/node": "^0.17.1",
    "@sentry/electron": "^7.7.1",
    "@showstack/shared": "workspace:*",
    "@supabase/supabase-js": "^2.95.2",
    "@types/better-sqlite3": "^7.6.13",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.6.2",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.4",
    "file-type": "^19.6.0",
    "lucide-react": "^0.460.0",
    "posthog-js": "^1.328.0",
    "puppeteer": "^24.34.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^6.28.0",
    "sql.js": "^1.10.3",
    "uuid": "^13.0.0",
    "zustand": "^5.0.8"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,json,md,css,yml,yaml}": [
      "prettier --write"
    ]
  }
}
