{
  "name": "showstack-production",
  "version": "0.1.0-alpha",
  "description": "Modern production management software for live entertainment",
  "author": "Josh Karp / Lytrix",
  "license": "UNLICENSED",
  "private": true,
  "type": "module",
  "main": "out/main/index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/jkarp7/showstack.git"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "rebuild": "npm install --build-from-source better-sqlite3@9.4.5 && npm run rebuild:electron",
    "rebuild:electron": "cd node_modules/better-sqlite3 && npm run install -- --target_arch=arm64 --target_platform=darwin --target=39.2.1",
    "postinstall": "npm run rebuild || true",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "dev:poc": "cd proof-of-concept && npm run dev",
    "build:poc": "cd proof-of-concept && npm run build",
    "test:poc": "cd proof-of-concept && npm test",
    "install:all": "npm install && cd proof-of-concept && npm install"
  },
  "keywords": [
    "lighting",
    "production",
    "theater",
    "entertainment",
    "lightwright",
    "electron"
  ],
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.17",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.22",
    "electron": "^39.2.1",
    "electron-builder": "^26.0.12",
    "electron-rebuild": "^3.2.9",
    "electron-vite": "^4.0.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.9.3",
    "vite": "^7.2.2"
  },
  "dependencies": {
    "better-sqlite3": "^12.4.1",
    "clsx": "^2.1.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "uuid": "^13.0.0",
    "zustand": "^5.0.8"
  }
}
