# PostHog Analytics Configuration
# Get your project API key from https://app.posthog.com/project/settings

# PostHog Project API Key (US Cloud)
# Leave empty to disable cloud sync (telemetry will be stored locally only)
VITE_POSTHOG_KEY=

# App Version (auto-populated from package.json)
VITE_APP_VERSION=0.1.0-alpha

# ============================================
# SUPABASE CONFIGURATION
# ============================================
# Get these from: Supabase Dashboard → Settings → API

# Your Supabase project URL (e.g., https://xxxxx.supabase.co)
SUPABASE_URL=

# Supabase anon/public key (safe to use in client-side code)
SUPABASE_ANON_KEY=

# Supabase service role key (⚠️ NEVER expose this in client code!)
# Only use this in Node.js/Electron main process
SUPABASE_SERVICE_ROLE_KEY=

# ============================================
# POWERSYNC CONFIGURATION
# ============================================
# Get these from: PowerSync Dashboard → Settings → Credentials

# PowerSync instance URL (e.g., https://xxxxx.powersync.com)
POWERSYNC_URL=

# PowerSync token (JWT token for authentication)
POWERSYNC_TOKEN=

# ============================================
# APPLICATION CONFIGURATION
# ============================================

# Environment (development, staging, production)
NODE_ENV=development

# Enable debug logging
DEBUG_DATABASE=false
DEBUG_POWERSYNC=false
