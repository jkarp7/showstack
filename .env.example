# PostHog Analytics Configuration
# Get your project API key from https://app.posthog.com/project/settings

# PostHog Project API Key (US Cloud)
# Leave empty to disable cloud sync (telemetry will be stored locally only)
VITE_POSTHOG_KEY=

# App Version (auto-populated from package.json)
VITE_APP_VERSION=0.1.0-alpha

# ============================================
# SUPABASE CONFIGURATION
# ============================================
# Get these from: Supabase Dashboard → Settings → API

# Your Supabase project URL (e.g., https://xxxxx.supabase.co)
SUPABASE_URL=

# Supabase anon/public key (safe to use in client-side code)
SUPABASE_ANON_KEY=

# Supabase service role key (⚠️ NEVER expose this in client code!)
# Only use this in Node.js/Electron main process
SUPABASE_SERVICE_ROLE_KEY=

# ============================================
# POWERSYNC CONFIGURATION
# ============================================
# PowerSync uses Supabase Auth - no separate token needed

# PowerSync instance URL (get from PowerSync Dashboard)
POWERSYNC_URL=

# ============================================
# SENTRY ERROR TRACKING
# ============================================
# Get your DSN from: Sentry Dashboard → Settings → Client Keys (DSN)

# Sentry DSN for the main (Node.js) process
# Leave empty to disable error tracking
SENTRY_DSN=

# Sentry DSN for the renderer (browser) process
# Uses VITE_ prefix so Vite exposes it to the renderer
VITE_SENTRY_DSN=

# ============================================
# APPLICATION CONFIGURATION
# ============================================

# Environment (development, staging, production)
NODE_ENV=development

# Enable debug logging
DEBUG_DATABASE=false
DEBUG_POWERSYNC=false
